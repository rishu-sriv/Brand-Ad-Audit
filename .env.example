# Copy this file to .env and set your real API key.
# Never commit .env.

# One key (used for every brand):
SEARCHAPI_KEY=your_searchapi_key_here

# Or multiple keys — audit.py rotates every 100 *SearchAPI requests* (not CSV rows):
# rows with no page_id / no fetch do not consume a key slot. Override batch size:
# SEARCHAPI_KEYS=key_a,key_b,key_c,key_d
# SEARCHAPI_KEY_BATCH_SIZE=100
